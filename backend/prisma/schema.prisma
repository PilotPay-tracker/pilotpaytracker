generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  accounts      Account[]
  passkeys      Passkey[]
  Profile       Profile?
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model Passkey {
  id           String    @id
  name         String?
  publicKey    String
  userId       String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  createdAt    DateTime? @default(now())
  aaguid       String?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passkey")
}

model Profile {
  id                              String    @id @default(cuid())
  userId                          String    @unique
  firstName                       String?
  lastName                        String?
  gemsId                          String?
  position                        String?
  base                            String?
  dateOfHire                      String?
  dateOfBirth                     String?
  hourlyRateCents                 Int       @default(32500)
  airline                         String    @default("UPS")
  onboardingComplete              Boolean   @default(false)
  onboardingStep                  Int       @default(0)
  aliasPackVersion                String?
  operatorType                    String?
  contractMappingStatus           String    @default("none")
  payRuleDefaultsApplied          Boolean   @default(false)
  calendarSyncConnected           Boolean   @default(false)
  trialStatus                     String    @default("not_started")
  trialStartDate                  DateTime?
  trialEndDate                    DateTime?
  subscriptionStatus              String    @default("inactive")
  subscriptionStartDate           DateTime?
  subscriptionEndDate             DateTime?
  revenuecatCustomerId            String?
  stripeCustomerId                String?
  stripeSubscriptionId            String?
  stripePriceId                   String?
  currentPeriodEnd                DateTime?
  plan                            String?
  creditCapPeriodType             String    @default("BID_56")
  creditCapAwardedLineCredit      Float     @default(0)
  creditCapIsRDGLine              Boolean   @default(false)
  creditCapAssignmentType         String    @default("DOMESTIC")
  creditCapExclusionVacation      Float     @default(0)
  creditCapExclusionTraining      Float     @default(0)
  creditCapExclusionJuniorManning Float     @default(0)
  creditCapExclusionCRAF          Float     @default(0)
  creditCapExclusionSick          Float     @default(0)
  creditCapAllowTripCompletion    Boolean   @default(false)
  creditCapTripCompletionOvercap  Float     @default(0)
  creditCapEnableVacationRelief   Boolean   @default(false)
  creditCapDroppedTripsCredit     Float     @default(0)
  creditCapHasVacationInPeriod    Boolean   @default(false)
  payYear                         Int?
  hourlyRateSource                String?
  adminRole                       String    @default("user")
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt
  user                            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile")
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  adminEmail   String
  adminUserId  String
  targetEmail  String?
  targetUserId String?
  actionType   String
  details      String?
  createdAt    DateTime @default(now())

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([actionType])
  @@index([createdAt])
  @@map("admin_audit_log")
}

model ContractVersion {
  id              String    @id @default(cuid())
  versionName     String
  effectiveDate   String
  notes           String?
  status          String    @default("draft")
  publishedAt     DateTime?
  publishedBy     String?
  payTableData    String?
  retirementRules String?
  guaranteeRules  String?
  reserveRules    String?
  sickRules       String?
  premiumRules    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([effectiveDate])
  @@index([status])
  @@map("contract_version")
}

model FlightEntry {
  id                     String   @id @default(cuid())
  userId                 String
  dateISO                String
  airline                String   @default("UPS")
  flightNumber           String?
  tailNumber             String?
  origin                 String?
  destination            String?
  originName             String?
  originCity             String?
  destinationName        String?
  destinationCity        String?
  aircraftIcaoType       String?
  aircraftModel          String?
  blockMinutes           Int      @default(0)
  flightMinutes          Int      @default(0)
  creditMinutes          Int      @default(0)
  outISO                 String?
  offISO                 String?
  onISO                  String?
  inISO                  String?
  payCode                String?
  premiumCode            String?
  premiumAmountCents     Int      @default(0)
  hourlyRateCentsAtEntry Int      @default(0)
  basePaoCents           Int      @default(0)
  overageMinutes         Int      @default(0)
  overagePaoCents        Int      @default(0)
  totalPayCents          Int      @default(0)
  notes                  String?
  photos                 String?
  flightAwareUrl         String?
  tripId                 String?
  dutyDayId              String?
  legIndex               Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
  @@index([dateISO])
  @@index([tripId])
  @@index([dutyDayId])
  @@map("flight_entry")
}

model LogbookImport {
  id                 String   @id @default(cuid())
  userId             String
  label              String
  totalBlockMinutes  Int      @default(0)
  totalFlightMinutes Int      @default(0)
  totalFlights       Int      @default(0)
  notes              String?
  startDateISO       String?
  endDateISO         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@map("logbook_import")
}

model Trip {
  id                       String             @id @default(cuid())
  userId                   String
  tripNumber               String?
  pairingId                String?
  matchKey                 String?
  source                   String             @default("manual")
  baseFleet                String?
  startDate                String
  endDate                  String
  totalBlockMinutes        Int                @default(0)
  totalCreditMinutes       Int                @default(0)
  totalDutyMinutes         Int                @default(0)
  totalPayCents            Int                @default(0)
  legCount                 Int                @default(0)
  dutyDaysCount            Int                @default(0)
  totalTafbMinutes         Int                @default(0)
  totalPdiemCents          Int                @default(0)
  premiumCents             Int                @default(0)
  status                   String             @default("scheduled")
  needsReview              Boolean            @default(false)
  originalRosterSnapshot   String?
  originalSnapshotSetAt    DateTime?
  currentRosterSnapshot    String?
  currentSnapshotUpdatedAt DateTime?
  protectedCreditMinutes   Int                @default(0)
  currentCreditMinutes     Int                @default(0)
  payCreditMinutes         Int                @default(0)
  changeSummary            String?
  changeSeverity           String             @default("none")
  acknowledgmentRequired   Boolean            @default(false)
  acknowledgedAt           DateTime?
  lastUploadId             String?
  premiumEventSuggestions  String?
  activeVersionId          String?
  pendingVersionId         String?
  hasChangePending         Boolean            @default(false)
  changePendingSince       DateTime?
  tripActionType           String             @default("none")
  pickupType               String             @default("none")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  dutyDays                 DutyDay[]
  logEvents                LogEvent[]
  rosterChanges            RosterChange[]
  tripDutyDays             TripDutyDay[]
  events                   TripEvent[]
  payProtection            TripPayProtection?
  versions                 TripVersion[]
  uploads                  Upload[]           @relation("TripToUpload")

  @@unique([userId, pairingId])
  @@unique([userId, matchKey])
  @@unique([userId, startDate, tripNumber])
  @@index([userId])
  @@index([startDate])
  @@index([endDate])
  @@index([pairingId])
  @@index([matchKey])
  @@index([userId, startDate, endDate])
  @@index([userId, status])
  @@index([hasChangePending])
  @@index([lastUploadId])
  @@map("trip")
}

model DutyDay {
  id                   String    @id @default(cuid())
  tripId               String
  dutyDate             String
  dutyStartISO         String?
  dutyEndISO           String?
  plannedCreditMinutes Int       @default(0)
  actualBlockMinutes   Int       @default(0)
  actualCreditMinutes  Int       @default(0)
  minCreditMinutes     Int       @default(360)
  finalCreditMinutes   Int       @default(0)
  totalPayCents        Int       @default(0)
  proofCount           Int       @default(0)
  hasAllActuals        Boolean   @default(false)
  hasPartialActuals    Boolean   @default(false)
  hasScheduleChange    Boolean   @default(false)
  scheduleChangeAt     DateTime?
  scheduleChangeReason String?
  scheduleChangeNotes  String?
  originalData         String?
  hasOverride          Boolean   @default(false)
  overrideAt           DateTime?
  overrideReason       String?
  overridePersist      Boolean   @default(true)
  premiumCode          String?
  premiumCreditMinutes Int       @default(0)
  premiumPayCents      Int       @default(0)
  premiumAppliedAt     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  trip                 Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  legs                 Leg[]

  @@index([tripId])
  @@index([dutyDate])
  @@map("duty_day")
}

model Leg {
  id                   String   @id @default(cuid())
  dutyDayId            String
  legIndex             Int      @default(0)
  flightNumber         String?
  origin               String?
  destination          String?
  equipment            String?
  tailNumber           String?
  isDeadhead           Boolean  @default(false)
  scheduledOutISO      String?
  scheduledInISO       String?
  plannedBlockMinutes  Int      @default(0)
  plannedCreditMinutes Int      @default(0)
  actualOutISO         String?
  actualOffISO         String?
  actualOnISO          String?
  actualInISO          String?
  actualFlightMinutes  Int      @default(0)
  actualBlockMinutes   Int      @default(0)
  creditMinutes        Int      @default(0)
  premiumCode          String?
  premiumAmountCents   Int      @default(0)
  calculatedPayCents   Int      @default(0)
  source               String   @default("import")
  ooiProofUri          String?
  ooiProofTimestamp    String?
  needsReview          Boolean  @default(false)
  wasEdited            Boolean  @default(false)
  editedAt             String?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  dutyDay              DutyDay  @relation(fields: [dutyDayId], references: [id], onDelete: Cascade)

  @@index([dutyDayId])
  @@map("leg")
}

model ScheduleBatch {
  id         String          @id @default(cuid())
  userId     String
  sourceType String
  importedAt DateTime        @default(now())
  startDate  String
  endDate    String
  status     String          @default("pending")
  confidence String          @default("provisional")
  rawImages  String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  events     ScheduleEvent[]

  @@index([userId])
  @@map("schedule_batch")
}

model ScheduleEvent {
  id               String        @id @default(cuid())
  batchId          String
  eventType        String
  dateLocal        String
  flightNumber     String?
  dep              String?
  arr              String?
  equipment        String?
  blockTimeMinutes Int?
  isDeadhead       Boolean       @default(false)
  isCommercial     Boolean       @default(false)
  layoverMinutes   Int?
  station          String?
  hotelName        String?
  hotelPhone       String?
  transportPhone   String?
  bookingStatus    String?
  rawText          String?
  confidence       Float         @default(0.8)
  needsReview      Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  batch            ScheduleBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([dateLocal])
  @@map("schedule_event")
}

model IROSegment {
  id              String   @id @default(cuid())
  userId          String
  legId           String?
  startISO        String
  endISO          String?
  durationMinutes Int      @default(0)
  role            String
  source          String   @default("manual")
  edited          Boolean  @default(false)
  editedAt        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([legId])
  @@map("iro_segment")
}

model PayPeriod {
  id           String @id @default(cuid())
  year         Int
  periodNumber Int
  startDate    String
  endDate      String
  payDate      String
  payType      String @default("standard")

  @@unique([year, periodNumber])
  @@map("pay_period")
}

model AircraftCache {
  id         String   @id @default(cuid())
  tailNumber String   @unique
  icaoType   String?
  model      String?
  operator   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("aircraft_cache")
}

model AirportCache {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String?
  city      String?
  country   String?
  latitude  Float?
  longitude Float?
  timezone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("airport_cache")
}

model TripEvent {
  id             String   @id @default(cuid())
  tripId         String
  dutyDayId      String?
  eventType      String
  startTimeLocal String?
  endTimeLocal   String?
  startTimeUtc   String?
  endTimeUtc     String?
  timezone       String?
  depAirport     String?
  arrAirport     String?
  station        String?
  flightMetadata String?
  layoverMinutes Int?
  hotelName      String?
  hotelPhone     String?
  hotelBooked    Boolean  @default(false)
  hotelAddress   String?
  transportNotes String?
  transportPhone String?
  creditMinutes  Int      @default(0)
  rawCreditText  String?
  minGuarantee   Boolean  @default(false)
  sortOrder      Int      @default(0)
  sourceType     String?
  confidence     Float    @default(0.8)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  trip           Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId])
  @@index([dutyDayId])
  @@index([eventType])
  @@map("trip_event")
}

model HotelProperty {
  id             String                @id @default(cuid())
  nameNormalized String
  displayName    String
  phone          String?
  city           String?
  airportCode    String?
  address        String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  mappings       LayoverHotelMapping[]
  transportNotes TransportNote[]

  @@unique([nameNormalized, airportCode])
  @@index([airportCode])
  @@map("hotel_property")
}

model LayoverHotelMapping {
  id              String        @id @default(cuid())
  base            String
  fleet           String?
  layoverAirport  String
  hotelPropertyId String
  confidenceScore Float         @default(0.5)
  evidenceCount   Int           @default(1)
  lastSeenAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  hotelProperty   HotelProperty @relation(fields: [hotelPropertyId], references: [id], onDelete: Cascade)

  @@unique([base, fleet, layoverAirport])
  @@index([layoverAirport])
  @@index([confidenceScore])
  @@map("layover_hotel_mapping")
}

model TransportNote {
  id              String         @id @default(cuid())
  base            String?
  fleet           String?
  layoverAirport  String
  hotelPropertyId String?
  noteText        String
  phone           String?
  confidenceScore Float          @default(0.5)
  evidenceCount   Int            @default(1)
  lastSeenAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  hotelProperty   HotelProperty? @relation(fields: [hotelPropertyId], references: [id])

  @@index([layoverAirport])
  @@index([hotelPropertyId])
  @@map("transport_note")
}

model TripDutyDay {
  id                   String        @id @default(cuid())
  tripId               String
  dutyDayIndex         Int
  dutyDate             String
  reportTimeISO        String?
  releaseTimeISO       String?
  dutyMinutes          Int           @default(0)
  blockMinutes         Int           @default(0)
  creditMinutes        Int           @default(0)
  restAfterMinutes     Int?
  layoverStation       String?
  hasScheduleChange    Boolean       @default(false)
  scheduleChangeAt     DateTime?
  scheduleChangeReason String?
  scheduleChangeNotes  String?
  originalData         String?
  hasOverride          Boolean       @default(false)
  overrideAt           DateTime?
  overrideReason       String?
  overridePersist      Boolean       @default(true)
  premiumCode          String?
  premiumCreditMinutes Int           @default(0)
  premiumPayCents      Int           @default(0)
  premiumAppliedAt     DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  trip                 Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  legs                 TripDutyLeg[]
  layover              TripLayover?

  @@unique([tripId, dutyDayIndex])
  @@index([tripId])
  @@index([dutyDate])
  @@map("trip_duty_day")
}

model TripDutyLeg {
  id                   String            @id @default(cuid())
  tripDutyDayId        String
  legIndex             Int
  flightNumber         String?
  origin               String?
  destination          String?
  equipment            String?
  isDeadhead           Boolean           @default(false)
  scheduledOutISO      String?
  scheduledInISO       String?
  actualOutISO         String?
  actualOffISO         String?
  actualOnISO          String?
  actualInISO          String?
  plannedBlockMinutes  Int               @default(0)
  plannedCreditMinutes Int               @default(0)
  actualBlockMinutes   Int               @default(0)
  creditMinutes        Int               @default(0)
  premiumCode          String?
  premiumAmountCents   Int               @default(0)
  legStatus            String            @default("FLY")
  legCompleted         Boolean           @default(false)
  legDateLocal         String?
  timezone             String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  logEventLegs         LogEventLeg[]
  sickCallLegLinks     SickCallLegLink[]
  tripDutyDay          TripDutyDay       @relation(fields: [tripDutyDayId], references: [id], onDelete: Cascade)

  @@unique([tripDutyDayId, legIndex])
  @@index([tripDutyDayId])
  @@index([legStatus])
  @@map("trip_duty_leg")
}

model TripLayover {
  id              String      @id @default(cuid())
  tripDutyDayId   String      @unique
  station         String
  restMinutes     Int
  hotelName       String?
  hotelPhone      String?
  hotelAddress    String?
  hotelStatus     String?
  hotelSource     String?
  hotelConfidence Float       @default(0.0)
  transportNotes  String?
  transportPhone  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  tripDutyDay     TripDutyDay @relation(fields: [tripDutyDayId], references: [id], onDelete: Cascade)

  @@index([station])
  @@map("trip_layover")
}

model UserHotelDirectory {
  id              String   @id @default(cuid())
  userId          String
  airlineCode     String
  station         String
  baseCode        String?
  equipmentCode   String?
  hotelName       String
  hotelPhone      String?
  hotelAddress    String?
  confirmCount    Int      @default(1)
  rejectCount     Int      @default(0)
  lastConfirmedAt DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  isShared        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, airlineCode, station, hotelName])
  @@index([userId])
  @@index([airlineCode, station])
  @@index([confirmCount])
  @@map("user_hotel_directory")
}

model SharedHotelDirectory {
  id              String   @id @default(cuid())
  airlineCode     String
  station         String
  baseCode        String?
  equipmentCode   String?
  hotelName       String
  hotelPhone      String?
  hotelAddress    String?
  confirmCount    Int      @default(1)
  userCount       Int      @default(1)
  lastConfirmedAt DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([airlineCode, station, hotelName])
  @@index([airlineCode, station])
  @@index([confirmCount])
  @@map("shared_hotel_directory")
}

model ScheduleEvidence {
  id              String   @id @default(cuid())
  userId          String
  tripId          String?
  sourceType      String   @default("unknown")
  imageUrl        String
  parseStatus     String   @default("pending")
  parseConfidence Float    @default(0.0)
  rawOcrText      String   @default("")
  parsedData      String   @default("{}")
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([tripId])
  @@map("schedule_evidence")
}

model Upload {
  id                  String               @id @default(cuid())
  userId              String
  sourceType          String
  imageUrl            String
  fileHash            String?
  status              String               @default("pending")
  errorMessage        String?
  uploadedAt          DateTime             @default(now())
  processedAt         DateTime?
  parseResultJson     String               @default("{}")
  parseConfidence     Float                @default(0.0)
  tripsCreated        Int                  @default(0)
  tripsUpdated        Int                  @default(0)
  tripsSkipped        Int                  @default(0)
  conflictsFound      Int                  @default(0)
  warningCount        Int                  @default(0)
  warningMessages     String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  logEventAttachments LogEventAttachment[]
  trips               Trip[]               @relation("TripToUpload")

  @@unique([userId, fileHash])
  @@index([userId])
  @@index([uploadedAt])
  @@index([sourceType])
  @@index([status])
  @@map("upload")
}

model LogEvent {
  id                  String               @id @default(cuid())
  userId              String
  tripId              String
  eventType           String
  premiumCode         String?
  premiumMinutesDelta Int?
  premiumMultiplier   Float?
  notes               String?
  autoGeneratedNotes  String?
  status              String               @default("draft")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  changeSummaryJson   String?
  appliesTo           String?
  contractReference   String?
  proofStatus         String?
  applicationStatus   String?
  eventDate           String?
  isPayAffecting      Boolean              @default(false)
  payDeltaCents       Int?
  dutyDayDate         String?
  aircraftType        String?
  position            String?
  trip                Trip                 @relation(fields: [tripId], references: [id], onDelete: Cascade)
  attachments         LogEventAttachment[]
  linkedLegs          LogEventLeg[]

  @@index([userId])
  @@index([tripId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([applicationStatus])
  @@map("log_event")
}

model LogEventAttachment {
  id             String   @id @default(cuid())
  logEventId     String
  uploadId       String?
  attachmentUrl  String?
  attachmentType String   @default("image")
  description    String?
  createdAt      DateTime @default(now())
  upload         Upload?  @relation(fields: [uploadId], references: [id])
  logEvent       LogEvent @relation(fields: [logEventId], references: [id], onDelete: Cascade)

  @@index([logEventId])
  @@index([uploadId])
  @@map("log_event_attachment")
}

model LogEventLeg {
  id            String      @id @default(cuid())
  logEventId    String
  tripDutyLegId String
  isPrimaryLeg  Boolean     @default(false)
  changeSummary String?
  createdAt     DateTime    @default(now())
  tripDutyLeg   TripDutyLeg @relation(fields: [tripDutyLegId], references: [id], onDelete: Cascade)
  logEvent      LogEvent    @relation(fields: [logEventId], references: [id], onDelete: Cascade)

  @@unique([logEventId, tripDutyLegId])
  @@index([logEventId])
  @@index([tripDutyLegId])
  @@map("log_event_leg")
}

