// ============================================
// BidPeriodBaseline — Originally awarded line credit per bid period.
// Stores the credit the pilot was AWARDED at bid time so the pay engine
// can correctly interpret pickups (filling guarantee gap vs. generating
// extra pay), drop effects, and guarantee applicability.
// ============================================
model BidPeriodBaseline {
  id                   String   @id @default(cuid())
  userId               String
  // Unique key for the period, e.g. "2026-P03" (year + UPS period number)
  periodKey            String
  periodStartISO       String
  periodEndISO         String
  // The credit the pilot was originally awarded for this bid period (minutes)
  awardedCreditMinutes Int      @default(0)
  // Source of the baseline: "uploaded_award" | "manual_entry" | "estimated"
  source               String   @default("manual_entry")
  // Human-readable note about the source (e.g. "Uploaded award screenshot")
  sourceNote           String?
  // Optional link to upload record if source = "uploaded_award"
  uploadId             String?
  // Confidence level: "high" (uploaded + parsed) | "medium" (manual) | "low" (estimated)
  confidence           String   @default("medium")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, periodKey])
  @@index([userId])
  @@index([periodKey])
  @@map("bid_period_baseline")
}
